# Provider options: ollama, mock, openai.
# mock is deterministic and reliable for recording demo takes.
AGENT_PROVIDER=mock

# Ollama local model settings. Used only when AGENT_PROVIDER=ollama.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional. Used only when AGENT_PROVIDER=openai.
OPENAI_API_KEY=

# Optional model override when using the OpenAI SDK.
OPENAI_MODEL=gpt-4o-mini
